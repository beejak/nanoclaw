# Copy to .env and fill in your values
# NEVER commit .env to git

# Telegram MTProto credentials (get from https://my.telegram.org/apps)
TG_API_ID=your_api_id_here
TG_API_HASH=your_api_hash_here

# Path to saved Pyrogram session file (no .session extension)
TG_SESSION=/path/to/tg_session

# Telegram bot token (from @BotFather)
BOT_TOKEN=your_bot_token_here

# Your Telegram chat ID (the bot sends reports here)
OWNER_CHAT_ID=your_chat_id_here
