[Unit]
Description=Claude memory file watcher — backs up on every change
After=network.target

[Service]
Type=simple
WorkingDirectory=/root/fin-assistant
ExecStart=/usr/bin/bash scripts/memory_backup.sh --watch
Restart=on-failure
RestartSec=15
StandardOutput=append:/root/fin-assistant/logs/memory_backup.log
StandardError=append:/root/fin-assistant/logs/memory_backup.log
Environment=PYTHONUNBUFFERED=1

[Install]
WantedBy=multi-user.target
